# Marketo API Credentials (required)
MARKETO_BASE_URL=https://xxx-xxx-xxx.mktorest.com
MARKETO_IDENTITY_URL=https://xxx-xxx-xxx.mktorest.com/identity
MARKETO_CLIENT_ID=
MARKETO_CLIENT_SECRET=

# MCP Server Config (optional)
MARKETO_MCP_PORT=3201
MCP_API_KEY=

# HTTPS (optional — provide paths to enable TLS)
MARKETO_MCP_HTTPS_PORT=3444
MCP_TLS_CERT=
MCP_TLS_KEY=

# Agent Config (optional — only needed for pnpm agent)
ANTHROPIC_API_KEY=
LANGCHAIN_MODEL=claude-sonnet-4-20250514
MARKETO_MCP_URL=http://localhost:3201/mcp
